{
  "name": "1st-line-training-portal",
  "version": "2.7.42",
  "description": "Training Portal Cloud Edition",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run dist:main",
    "dist:main": "electron-builder -p always --config.publish.releaseType=release",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacopersonal1-sys/1st-line-training-portal.git"
  },
  "author": "Admin",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.1.8",
    "env-paths": "^2.2.1",
    "fs-extra": "^11.2.0",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.1stline.trainingportal",
    "productName": "1st Line Training Portal",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "ico.ico",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "**/*",
      "!database.json",
      "!backups/**/*",
      "!save_data.php",
      "!server.js"
    ]
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jacopersonal1-sys/1st-line-training-portal/issues"
  },
  "homepage": "https://github.com/jacopersonal1-sys/1st-line-training-portal#readme"
}
